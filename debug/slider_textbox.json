{
  "namespace": "BP_DEBUG_slider_textbox",
  "count_t_box@common.text_edit_box": {
    "size": [24, 20],
    "$text_edit_box_content_binding_name": "#count_t_bind",
    "$text_alignment": "center",
    "max_length": 3,
    "$wrap": false,
    "text_type": "NumberChars",
    "$focus_override_up": "FOCUS_OVERRIDE_STOP"
  },
  "count_slider@common.empty_panel": {
    "size": [24, "100%c"],
    "controls": [
      {
        "slider_count@common.slider": {
          "size": [12, 128],
          "$slider_name": "slider_count",
          "anchor_from": "top_middle",
          "anchor_to": "top_middle",
          "$slider_direction": "vertical",
          "layer": 99,
          "$slider_steps|default": 30,
          "$slider_value|default": 2,
          "property_bag": {
            "#slider_value": "$slider_value",
            "#slider_steps": "$slider_steps"
          },
          "slider_inverted": true,
          "$slider_box_size": [16, 10],
          "$progress_clip_direction": "down",
          "$slider_progress_color": [1, 0.5, 1]
        }
      }
    ]
  },
  "main": {
    "type": "stack_panel",
    "size": [24, "100%c"],
    "orientation": "vertical",
    "controls": [
      {
        "count_t_box@BP_DEBUG_slider_textbox.count_t_box": {}
      },
      {
        "count_slidera@BP_DEBUG_slider_textbox.count_slider": {}
      },
      {
        "test_l": {
          "type": "label",
          "size": [24, 20],
          "text": "#text",
          "bindings": [
            {
              "source_control_name": "slider_count",
              "binding_type": "view",
              "source_property_name": "#slider_value",
              "target_property_name": "#val"
            },
            {
              "binding_type": "view",
              "source_property_name": "(10*((#val > 9) + (#val > 19) + (#val > 29) + (#val > 39) + (#val > 49) + (#val > 59) + (#val > 69) + (#val > 79) + (#val > 89)))",
              "target_property_name": "#tenner"
            },
            {
              "binding_type": "view",
              "source_property_name": "(#val - #tenner)",
              "target_property_name": "#onner"
            },
            {
              "binding_type": "view",
              "source_property_name": "((#onner > 0) + (#onner > 1) + (#onner > 2) + (#onner > 3) + (#onner > 4) + (#onner > 5) + (#onner > 6) + (#onner > 7) + (#onner > 8))",
              "target_property_name": "#onner_dig"
            },
            {
              "binding_type": "view",
              "source_property_name": "(#onner_dig + #tenner + 1)",
              "target_property_name": "#digit"
            },
            {
              "binding_type": "view",
              "source_property_name": "('§r' + #digit)",
              "target_property_name": "#text"
            }
          ]
        }
      }
    ]
  }
}
